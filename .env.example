# ══════════════════════════════════════════════════════════════════
#  LearnForge — Environment Template
#  Copy this file to .env and fill in real values before starting.
#
#  NEVER commit .env — it is listed in .gitignore.
# ══════════════════════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_DB=learnforge
POSTGRES_USER=learnforge
# Choose a strong, unique password (used only inside the Docker network)
POSTGRES_PASSWORD=change_me_db_password

DATABASE_URL=postgresql+asyncpg://learnforge:change_me_db_password@postgres:5432/learnforge
DATABASE_URL_SYNC=postgresql+psycopg2://learnforge:change_me_db_password@postgres:5432/learnforge

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT / Auth ──────────────────────────────────────────────────
# REQUIRED: Generate with:  openssl rand -hex 32
JWT_SECRET=replace_this_with_a_64_char_random_hex_string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# ── Piston Code Runner ──────────────────────────────────────────
PISTON_URL=http://piston:2000

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:5174,http://localhost

# ── Lab Governance ──────────────────────────────────────────────
MAX_CONCURRENT_LABS=3
LAB_TTL_MINUTES=120

# ── Default Admin Account ───────────────────────────────────────
# REQUIRED: Change before first launch — this account is created on first run.
DEFAULT_ADMIN_EMAIL=admin@learnforge.dev
# Must be ≥8 chars with uppercase, lowercase, and a digit
DEFAULT_ADMIN_PASSWORD=ReplaceWithAStrongPassword1!
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_DISPLAY_NAME=Admin
