.env
.env.*
!.env.example

# ── Coverage / Test artefacts ───────────────────────────────────
.coverage
coverage/
htmlcov/
.pytest_cache/
.mypy_cache/

# ── OS artefacts ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Docker volumes / local data ─────────────────────────────────
postgres-data/
redis-data/

