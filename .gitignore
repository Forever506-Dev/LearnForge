# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
.eggs/
dist/
build/
*.so
.Python
.venv/
venv/
env/

# ── Node / JavaScript ───────────────────────────────────────────
node_modules/
dist/
.vite/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Environment / Secrets ───────────────────────────────────────
